# ===== TraceBack 溯·源 配置 =====

# ===== LLM 多模型配置 =====
# 主力模型：DeepSeek-V3.2（本体生成、图谱构建、报告生成）
LLM_API_KEY=your_api_key_here
LLM_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
LLM_MODEL_NAME=deepseek-v3-2-251201

# 推理模型：Doubao-Seed-2.0-pro（回溯分析质证辩论，支持深度思考）
LLM_REASONING_API_KEY=your_api_key_here
LLM_REASONING_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
LLM_REASONING_MODEL_NAME=doubao-seed-2-0-pro-260215

# 轻量模型：Doubao-Seed-2.0-mini（高频chunk抽取，图谱构建加速）
LLM_FAST_API_KEY=your_api_key_here
LLM_FAST_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
LLM_FAST_MODEL_NAME=doubao-seed-2-0-mini-260215

# ===== 搜索引擎配置 =====
# 默认使用Bocha（国产直连），可选: bocha/tavily/duckduckgo/serper
SEARCH_PROVIDER=bocha
SEARCH_API_KEY=your_api_key_here

# Tavily备用（如需切换，改SEARCH_PROVIDER=tavily 并改SEARCH_API_KEY）
TAVILY_API_KEY=your_tavily_api_key_here

# ===== 知识图谱 =====
# Zep Cloud 图谱服务（加速图谱构建）
ZEP_API_KEY=your_zep_api_key_here

# ===== TraceBack 分析配置 =====
TRACEBACK_MAX_DEBATE_ROUNDS=3
TRACEBACK_MIN_EVIDENCE_CONFIDENCE=0.3
