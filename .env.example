# ===== TraceBack 溯·源 配置 =====

# LLM API配置（支持 OpenAI SDK 格式的任意 LLM API）
# 推荐使用阿里百炼平台qwen-plus模型：https://bailian.console.aliyun.com/
LLM_API_KEY=your_api_key_here
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_MODEL_NAME=qwen-plus

# ===== ZEP记忆图谱配置 =====
# 每月免费额度即可支撑简单使用：https://app.getzep.com/
ZEP_API_KEY=your_zep_api_key_here

# ===== 搜索引擎配置 =====
# 默认使用 DuckDuckGo（免费，无需API Key，中国可用）
# 可选: duckduckgo / serper / bocha
SEARCH_PROVIDER=duckduckgo
# 仅 serper/bocha 需要填写 API Key：
# Serper: https://serper.dev （注册送2500次免费）
# Bocha: https://bochaai.com （国产，中国直连）
# SEARCH_API_KEY=your_search_api_key_here
SEARCH_MAX_RESULTS=10

# ===== TraceBack 分析配置 =====
TRACEBACK_MAX_DEBATE_ROUNDS=3
TRACEBACK_MIN_EVIDENCE_CONFIDENCE=0.3
